# Environment Variables for Portfolio Backend
# Copy this file to .env and fill in your actual values

# Langbase API Key (required)
LANGBASE_API_KEY=pipe_XXXX // Replace XXXX with your Langbase API key

# Server Configuration
PORT=3001 // Replace 3001 with your desired port

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-portfolio.netlify.app // Replace with your actual origins

# Environment
NODE_ENV=production // Replace production with your actual environment
